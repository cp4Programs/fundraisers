# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
AUTH_URL=http://localhost:3000

# DynamoDB (set after running `npx ampx sandbox` or from Amplify outputs)
FUNDRAISER_TABLE_NAME=
NEXTAUTH_TABLE_NAME=

# S3 bucket for dancer photos and share images
FUNDRAISER_ASSETS_BUCKET=

# Optional: explicit AWS credentials for Auth.js DynamoDB adapter (otherwise uses default chain)
# AUTH_DYNAMODB_ID=
# AUTH_DYNAMODB_SECRET=
# AUTH_DYNAMODB_REGION=us-east-1
